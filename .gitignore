```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out
*.class

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
*.env.*

# Build directories
dist/
build/
target/
.coverage
coverage/
htmlcov/

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# Editor/IDE files
.vscode/
.idea/
*.pyc
__pycache__/

# System files
.DS_Store
Thumbs.db

# Cache directories
.mypy_cache/
.pytest_cache/
.gradle/
```