```gitignore
# Compiled and binary files
*.pyc
__pycache__/
*.class
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
.env.*

# Build artifacts
dist/
build/
target/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs
*.log

# Coverage
coverage/
htmlcov/
.coverage

# OS files
.DS_Store
Thumbs.db

# Cache directories
.mypy_cache/
.pytest_cache/
.gradle/
```