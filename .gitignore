Thumbs.db

# Python specific
*.pyc
__pycache__/
*.pyo
*.pyd
.Python
*.so
.Python
*.egg-info/
.eggs/

# JavaScript/Node specific
npm-debug.log*
yarn-debug.log*
yarn-error.log*
node_modules/
dist/
build/
.next/
.nuxt/

# Java specific
*.class
*.jar
*.war
*.ear
target/
.gradle/
build/

